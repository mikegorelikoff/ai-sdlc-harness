{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-sdlc.local/schemas/ai-sdlc-module-v1.json",
  "title": "AI SDLC module manifest",
  "type": "object",
  "required": ["schema", "id", "version", "kind", "harness_api", "skills"],
  "properties": {
    "schema": {"const": "ai-sdlc-module/v1"},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "kind": {"enum": ["core", "optional"]},
    "harness_api": {
      "type": "object",
      "required": ["min", "max_exclusive"],
      "properties": {
        "min": {"type": "string"},
        "max_exclusive": {"type": "string"}
      },
      "additionalProperties": false
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path"],
        "properties": {
          "name": {"type": "string"},
          "path": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "requires": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "description": {"type": "string"}
  },
  "additionalProperties": false
}
