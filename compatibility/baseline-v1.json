  "required_cli_flags": ["--quick-flow", "--full-flow", "--state-check", "--begin-state", "--complete-state"],
  "skill_doc_contract": [
    "## 0.5 Feature State Machine",
    "## 0.6 Artifact Metadata And Metatags",
    "## 0.7 Specs Index",
    "_ai_sdlc/state.toon",
    "_ai_sdlc/specs-index.toon",
    "specs-index.md",
    "artifact_metadata",
    "metatags",
    "ai-sdlc-handoff/v1",
    "next_required",
    "next_optional",
    "Do not create `summary.txt`",
    "directly in the Codex response"
  ],
  "routes": {
    "refinement": "specs-refiniment/<feature>",
    "implementation": "specs/<feature>",
    "machine_directory": "_ai_sdlc",
    "state": "_ai_sdlc/state.toon",
    "workspace_index": "_ai_sdlc/specs-index.toon"
  },
  "config": {"schema": "ai-sdlc-config/v1", "defaults": "config/ai-sdlc.defaults.json"},
  "modules": {
    "schema": "ai-sdlc-module/v1",
    "ids": ["architecture", "core", "evidence-council", "research", "ux"]
  },
  "install_update_guide": "guides/install-and-update.md",
  "roadmap_commit_subjects": [
    "feat(sdd): establish adaptive harness roadmap",
    "feat(navigator): recommend evidence-backed next actions",
    "feat(workflow): standardize post-workflow handoffs",
    "feat(policy): add explainable adaptive rigor",
    "feat(context): add evidence-backed project memory",
    "feat(quality): add traceable reusable review lenses",
    "feat(recovery): add evidence-backed change impact",
    "feat(learning): add governed delivery retrospectives",
    "feat(config): add protected layered customization",
    "feat(modules): add compatible capability discovery",
    "feat(architecture): add optional traced design capability",
    "feat(ux): add optional traced experience capability",
    "feat(research): add optional sourced evidence capability",
    "feat(council): add authority-safe evidence reviews",
    "chore(compat): validate adaptive harness release"
  ]
}
