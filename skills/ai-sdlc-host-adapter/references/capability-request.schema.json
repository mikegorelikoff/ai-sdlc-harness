{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "ai-sdlc-capability-request/v1",
  "type": "object", "additionalProperties": false,
  "required": ["schema", "operations", "capabilities", "concurrency", "isolation_required"],
  "properties": {
    "schema": {"const": "ai-sdlc-capability-request/v1"},
    "operations": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "capabilities": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "concurrency": {"type": "integer", "minimum": 1, "maximum": 64},
    "isolation_required": {"type": "boolean"}
  }
}
