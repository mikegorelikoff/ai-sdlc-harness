# Derived AI context packs are reproducible from source artifacts.
specs/*/.ai-sdlc/context/
specs-refiniment/*/.ai-sdlc/context/
specs/*/_ai_sdlc/context/
specs-refiniment/*/_ai_sdlc/context/
specs/*/_ai_sdlc/feature-context.toon
specs-refiniment/*/_ai_sdlc/feature-context.toon
specs/**/_ai_sdlc/.write.lock
specs-refiniment/**/_ai_sdlc/.write.lock

# Documentation build output is generated by the deployment workflow.
_site/
site/

# Python validation and test caches are generated locally and must never be
# included in an installed baseline or feature commit.
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.env
.env.*
!.env.example
!.env.sample
